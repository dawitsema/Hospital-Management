# --- MongoDB ---
# ECONNREFUSED on 127.0.0.1:27017 means nothing is listening there: either
# start MongoDB locally, or use Atlas and set MONGODB_URI to your cluster URL.

# Local (default): requires `mongod` / MongoDB Community running on your machine
MONGODB_URI=mongodb://127.0.0.1:27017/hospital_appointments

# Atlas example (uncomment and paste from Atlas → Connect → Drivers):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/hospital_appointments?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-string-in-production
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# When true, POST /api/auth/forgot-password includes resetToken in the JSON body (demo only — never enable in production).
AUTH_RETURN_RESET_TOKEN=false
